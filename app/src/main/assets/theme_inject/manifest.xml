          <Text x="#layerLeftBuffer_LDnWwt6B" y="((#safeAreaMarginTop_LDnWwt6B - #timeAreaMarginTop_LDnWwt6B) + ((#safeAreaHeight_LDnWwt6B - #sig_text.text_height) / 2))" size="#fontSize_LDnWwt6B" spacingMultExp="#lineHeight_LDnWwt6B" fontPath="@fontPath_LDnWwt6B" fontPathWeight="#signatureBold_LDnWwt6B" color="@aodTextColor_LDnWwt6B" textExp="@signatureText_LDnWwt6B" w="#safeAreaWidth_LDnWwt6B" textAlign="@textAlign_LDnWwt6B" lineClamp="#maxRows_LDnWwt6B" name="sig_text" multiLine="true" ellipsis="true" enableClip="false"/>
          <Text visibility="(#showTime_LDnWwt6B == 1)" x="#layerLeftBuffer_LDnWwt6B" y="(#timeAreaHeight_LDnWwt6B / 2)" w="#safeAreaWidth_LDnWwt6B" size="#timeSize_LDnWwt6B" spacingMultExp="#lineHeight_LDnWwt6B" fontPath="@fontPath_LDnWwt6B" color="@aodTextColor_LDnWwt6B" textExp="formatDate(@timeFormat_LDnWwt6B,#time_sys)" textAlign="@textAlign_LDnWwt6B" name="time_text" alignV="center" enableClip="false"/>
        </Layer>
      </Group>
    </Group>
    <Group x="#viewMarginLeft_LDnWwt6B" y="#timeAreaMarginTop_LDnWwt6B" w="#safeAreaWidth_LDnWwt6B" h="#timeAreaHeight_LDnWwt6B" contentDescriptionExp="formatDate(@timeFormat_LDnWwt6B,#time_sys)" visibility="(eq(#aod_state_LDnWwt6B,0) ** (#showTime_LDnWwt6B == 1))"/>
  </Group>
  <Group>
    <FolmeState name="folme_state_0" alpha="(255 * 0.4)"/>
    <FolmeConfig name="folme_config_0" ease="-2, 1,0.72"/>
    <FolmeState name="folme_state_1" alpha="0"/>
    <FolmeConfig name="folme_config_1" ease="-2, 1,0.5"/>
    <FolmeState name="folme_state_2" alpha="255"/>
    <FolmeConfig name="folme_config_2" ease="-2, 1,0.72" onComplete="'folme_oncomplete_3'"/>
    <Function name="folme_oncomplete_3">
      <FrameRateCommand rate="0"/>
    </Function>
    <FolmeState name="folme_state_3" alpha="0"/>
    <FolmeConfig name="folme_config_3" ease="-2, 1,0.5"/>
    <FolmeState name="folme_state_4" alpha="255"/>
    <FolmeConfig name="folme_config_4" ease="-2, 1,0.72" onComplete="'folme_oncomplete_5'"/>
    <Function name="folme_oncomplete_5">
      <FrameRateCommand rate="0"/>
    </Function>
    <FolmeState name="folme_state_5" alpha="0"/>
    <FolmeConfig name="folme_config_5" ease="-2, 1,0.5"/>
  </Group>
  <!-- MiRoot 参考：三方向手势发通用槽位广播（与 AiRearscreenLyricsGestureInjector 注入结果一致）；主题开关见 var_config.xml -->
  <Group name="miroot_gesture_inject" visibility="(((#miroot_bottom_swipe_up_on == 1) || (#miroot_bottom_swipe_left_on == 1)) || (#miroot_bottom_swipe_right_on == 1))">
    <Function name="miroot_emit_s1">
      <IntentCommand action="com.wmqc.miroot.rear.ACTION_REAR_BOTTOM_GESTURE" broadcast="true" package="com.wmqc.miroot">
        <Extra name="com.wmqc.miroot.rear.EXTRA_GESTURE_SLOT" type="number" expression="1"/>
      </IntentCommand>
    </Function>
    <Function name="miroot_emit_s2">
      <IntentCommand action="com.wmqc.miroot.rear.ACTION_REAR_BOTTOM_GESTURE" broadcast="true" package="com.wmqc.miroot">
        <Extra name="com.wmqc.miroot.rear.EXTRA_GESTURE_SLOT" type="number" expression="2"/>
      </IntentCommand>
    </Function>
    <Function name="miroot_emit_s3">
      <IntentCommand action="com.wmqc.miroot.rear.ACTION_REAR_BOTTOM_GESTURE" broadcast="true" package="com.wmqc.miroot">
        <Extra name="com.wmqc.miroot.rear.EXTRA_GESTURE_SLOT" type="number" expression="3"/>
      </IntentCommand>
    </Function>
    <Button name="miroot_bottom_gesture" x="0" y="(#view_height - (80 * #vsy))" w="#view_width" h="(80 * #vsy)" interceptTouch="true">
      <Normal>
      </Normal>
      <Pressed>
      </Pressed>
      <Triggers>
        <Trigger action="up,cancel">
          <IfCommand ifCondition="((#miroot_bottom_swipe_up_on == 1) ** (#touch_begin_y }= (#view_height - (80 * #vsy))) ** ((#touch_begin_y - #touch_y) }= (50 * #vsy)) ** ((#touch_begin_y - #touch_y) }= (abs(#touch_x - #touch_begin_x) + (24 * #vsy))))">
            <Consequent>
              <FunctionCommand target="miroot_emit_s1"/>
            </Consequent>
          </IfCommand>
          <IfCommand ifCondition="((#miroot_bottom_swipe_left_on == 1) ** (#touch_begin_y }= (#view_height - (80 * #vsy))) ** ((#touch_begin_x - #touch_x) }= (0.07 * #view_width)) ** ((#touch_begin_x - #touch_x) }= (abs(#touch_begin_y - #touch_y) + (24 * #vsy))))">
            <Consequent>
              <FunctionCommand target="miroot_emit_s2"/>
            </Consequent>
          </IfCommand>
          <IfCommand ifCondition="((#miroot_bottom_swipe_right_on == 1) ** (#touch_begin_y }= (#view_height - (80 * #vsy))) ** ((#touch_x - #touch_begin_x) }= (0.07 * #view_width)) ** ((#touch_x - #touch_begin_x) }= (abs(#touch_begin_y - #touch_y) + (24 * #vsy))))">
            <Consequent>
              <FunctionCommand target="miroot_emit_s3"/>
            </Consequent>
          </IfCommand>
        </Trigger>
      </Triggers>
    </Button>
  </Group>
  <ExternalCommands>
    <Trigger action="init">
      <IfCommand ifCondition="eqs(@isPreviewMode,'true')">
        <Consequent>
          <FrameRateCommand rate="120"/>
        </Consequent>
        <Alternate>
          <FrameRateCommand rate="0"/>
        </Alternate>
      </IfCommand>
    </Trigger>
    <Trigger action="init">
      <IfCommand ifCondition="eqs(@isPreviewMode,'true')">
        <Consequent>
          <VideoCommand target="aiVideo" command="config" path="'assets/ai/ai.mp4'" loop="0" scaleMode="2"/>
          <VideoCommand target="aiVideo" command="setVolume" volume="0"/></Consequent>
        <Alternate>
          <VideoCommand target="aiVideo" command="config" path="'assets/ai/ai.mp4'" loop="0" scaleMode="2"/>
          <VideoCommand target="aiVideo" command="setVolume" volume="0"/></Alternate>
      </IfCommand>
    </Trigger>
    <Trigger action="resume">
      <MultiCommand condition="((! #aod_state_8i5TKF4T) ** #is_paused_8i5TKF4T)">
        <FunctionCommand target="replayVideo"/>
      </MultiCommand>
      <MultiCommand condition="(! #is_paused_8i5TKF4T)">
        <FunctionCommand target="playVideo"/>
      </MultiCommand>
      <MultiCommand condition="(#isDisplayDefaultBg_8i5TKF4T == 1)">
        <FunctionCommand target="releaseVideo"/>
      </MultiCommand>
    </Trigger>
    <Trigger action="pause">
      <FunctionCommand target="pauseVideo"/>
      <VariableCommand name="is_paused_8i5TKF4T" expression="1" type="number"/>
    </Trigger>
    <Trigger action="enterAod">
      <VariableCommand name="aod_state_8i5TKF4T" expression="1" type="number"/>
    </Trigger>
    <Trigger action="exitAod">
      <VariableCommand name="aod_state_8i5TKF4T" expression="0" type="number"/>
      <MultiCommand condition="((#is_finished_8i5TKF4T == 1) || (#is_paused_8i5TKF4T == 1))">
        <FunctionCommand target="replayVideo"/>
      </MultiCommand>
    </Trigger>
    <Trigger action="enterEdit">
      <VariableCommand name="is_edit_8i5TKF4T" expression="1" type="number"/>
      <MultiCommand condition="eq(#selected,0)">
        <VariableCommand name="is_finished_8i5TKF4T" expression="1" type="number"/>
        <FunctionCommand target="setVideoFirstFrame"/>
        <FunctionCommand target="pauseVideo"/>
      </MultiCommand>
    </Trigger>
    <Trigger action="exitEdit">
      <VariableCommand name="is_edit_8i5TKF4T" expression="0" type="number"/>
      <MultiCommand condition="(#is_finished_8i5TKF4T == 1)">
        <FunctionCommand target="replayVideo"/>
      </MultiCommand>
    </Trigger>
    <Trigger action="enterAod">
      <FunctionCommand target="switchStateAod"/>
      <VariableCommand name="aod_state_LDnWwt6B" expression="1" type="number"/>
      <ExternCommand command="__clearTalkback"/>
    </Trigger>
    <Trigger action="exitAod">
      <FunctionCommand target="switchStateDesk"/>
      <VariableCommand name="aod_state_LDnWwt6B" expression="0" type="number"/>
      <ExternCommand command="__clearTalkback"/>
    </Trigger>
  </ExternalCommands>
</Widget>
