        <package android:name="com.miui.securitycenter" />
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:enableOnBackInvokedCallback="false"
        android:icon="@mipmap/ic_launcher_v2"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_v2_round"
        android:name=".MiRootApplication"
        android:supportsRtl="true"
        android:theme="@style/Theme.MiRoot"
        android:networkSecurityConfig="@xml/network_security_config">

        <!--
          Target API 36閿涙艾婀?sw600dp+ 婢堆冪潌娑撳﹦閮寸紒鐔肩帛鐠併倕鎷烽悾銉︽煙閸?濮ｆ柧绶ラ梽鎰煑閿?
          閼冲苯鐫嗗宀冪槤缁涘绶风挧?setRequestedOrientation閿涘本娈忔穱婵堟殌閸忕厧顔愬Ο鈥崇础閿涘湏PI 37 鐠у嘲鐨㈡径杈ㄦ櫏閿涘矂娓堕弨閫涜礋閼奉亪鈧倸绨茬敮鍐ㄧ湰閿涘鈧?
        -->
        <property
            android:name="android.window.PROPERTY_COMPAT_ALLOW_RESTRICTED_RESIZABILITY"
            android:value="true" />

        <!-- 棣冩斀 閸忔娊鏁敍姘冲剹鐏炲繐鍣崗銉ㄧ槈閿涗礁鍑℃宀冪槈閺堝鏅ラ敍?-->
        <meta-data
            android:name="miui.rear.policy"
            android:value="1"/>

        <!-- SuperLyric API 閹恒儱鍙嗘竟鐗堟 -->
        <meta-data
            android:name="superlyricapi"
            android:value="true"
            tools:replace="android:value" />
        <meta-data
            android:name="superlyricapi_version_name"
            android:value="${superlyricApiVersionName}"
            tools:replace="android:value" />
        <meta-data
            android:name="superlyricapi_version_code"
            android:value="${superlyricApiVersionCode}"
            tools:replace="android:value" />

        <provider
            android:name="rikka.shizuku.ShizukuProvider"
