<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.MiRoot.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mi_text_primary</item>
    </style>

    <style name="TextAppearance.MiRoot.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/mi_text_secondary</item>
    </style>

    <style name="TextAppearance.MiRoot.BodyStrong" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mi_text_primary</item>
    </style>

    <!-- 与音乐页主标题（SemiBold + @dimen/mi_page_title_text_size）一致 -->
    <style name="TextAppearance.MiRoot.PageTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/mi_page_title_text_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mi_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- 卡片内首标题：与音乐页 Compose SectionTitleBar（19sp + sans-serif-medium）一致 -->
    <style name="TextAppearance.MiRoot.CardSectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/mi_card_section_title_text_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mi_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- 卡片内二级分组标题：对齐 Miuix body2 + 次要色（介于首标题与开关之间） -->
    <style name="TextAppearance.MiRoot.CardSectionSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/mi_text_secondary</item>
    </style>

    <!-- 与音乐页 ToggleRow 文案（Miuix body1）一致：主色正文开关标题 -->
    <style name="TextAppearance.MiRoot.SwitchLabel" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/mi_text_primary</item>
    </style>

    <!-- 与音乐页 SliderRow 左侧标题（footnote1 + 次要色）一致 -->
    <style name="TextAppearance.MiRoot.CardSliderLabel" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/mi_text_secondary</item>
    </style>

    <!-- 与音乐页 Miuix Card 一致：@color/mi_card_surface、圆角、无描边、无阴影 -->
    <style name="Widget.MiRoot.Card.Shape" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/mi_corner_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.MiRoot.Card" parent="Widget.MiRoot.Card.Shape">
        <item name="cardBackgroundColor">@color/mi_card_surface</item>
    </style>

    <!-- 状态页顶部权限卡片：形状与上同，填充色由 PermissionFragment 按 Root/Shizuku 状态设置 -->
    <style name="Widget.MiRoot.Card.PermissionStatus" parent="Widget.MiRoot.Card.Shape" />

    <!-- 全应用 XML 界面 MaterialButton 统一：圆角与主色主题一致，变体语义与 Material3 相同 -->
    <style name="Widget.MiRoot.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/mi_corner_radius</item>
    </style>
    <style name="Widget.MiRoot.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">@dimen/mi_corner_radius</item>
    </style>
    <style name="Widget.MiRoot.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/mi_corner_radius</item>
    </style>
    <style name="Widget.MiRoot.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">@dimen/mi_corner_radius</item>
    </style>
</resources>
