<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MiRoot.Transparent" parent="Theme.MiRoot">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <!-- 对齐 3.4 老版：透明占位窗必须禁用 dim，否则启动/转场阶段会“黑一下” -->
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <!-- 用于“占位但必须有 UI”的 Activity：透明 + 禁用 preview，避免 StartingWindow/闪黑。 -->
    <style name="Theme.MiRoot.Transparent.NoPreview" parent="Theme.MiRoot.Transparent">
        <item name="android:windowDisablePreview">true</item>
        <!-- Android 12+ SplashScreen：强制透明，避免主屏占位启动时闪黑/闪底色 -->
        <item name="android:windowSplashScreenBackground">@android:color/transparent</item>
        <item name="android:windowSplashScreenAnimatedIcon">@null</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
    </style>

    <!-- API&lt;R 单屏路径用；背屏常规路径 Activity 主题为 Theme.MiRoot.Transparent，内容由窗口/布局设为不透。 -->
    <style name="Theme.MiRoot.ChargingRear" parent="Theme.MiRoot">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@color/charging_window_bg</item>
        <item name="android:colorBackground">@color/charging_window_bg</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:colorBackgroundCacheHint">@color/charging_window_bg</item>
    </style>
</resources>
