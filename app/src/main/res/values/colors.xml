    <color name="charging_window_bg">#FF0A1628</color>
    <color name="white">#FFFFFFFF</color>

    <!-- ========== Miuix 风格主色体系 ========== -->
    <color name="miuix_primary">#FF3482FF</color>
    <color name="miuix_on_primary">#FFFFFFFF</color>
    <color name="miuix_primary_container">#FFD6E6FF</color>
    <color name="miuix_on_primary_container">#FF0D3B82</color>
    <color name="miuix_surface">#FFFFFFFF</color>
    <color name="miuix_surface_container">#FFF7F8FA</color>

