<?xml version="1.0" encoding="utf-8"?>
<!--
  防抓包：仅信任系统 CA（不信任用户安装的抓包根证书）。
  不限制明文 HTTP，第三方歌词/曲库等 HTTP 接口可直接访问。
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- 仅信任系统 CA，不信任用户 CA（抓包工具常靠安装用户证书做 MITM） -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- 允许本地回环和局域网明文 HTTP（MiClaw MCP 连接）-->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.0.0/16</domain>
        <domain includeSubdomains="false">10.0.0.0/8</domain>
    </domain-config>
</network-security-config>

