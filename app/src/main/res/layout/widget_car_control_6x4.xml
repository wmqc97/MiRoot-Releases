<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="true"
    android:clipToPadding="true"
    android:padding="4dp">

    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="fitXY" />

    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- 顶栏：车牌 + 更新时间 + 刷新 -->
        <LinearLayout
            android:id="@+id/widget_top_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/widget_info_column"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:id="@+id/widget_range_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:baselineAligned="true"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/widget_plate_value"
                        style="@style/WidgetCarControlTextPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="bottom"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/widget_range_value"
                        style="@style/WidgetCarControlTextPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="bottom"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="---"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/widget_range_unit"
                        style="@style/WidgetCarControlTextSecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:gravity="bottom"
                        android:textSize="10sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/widget_range_label"
                        style="@style/WidgetCarControlTextSecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:gravity="bottom"
                        android:textSize="10sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_car_column"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/widget_meta_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/widget_time_value"
                        style="@style/WidgetCarControlTextSecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/widget_refresh_btn"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:contentDescription="@string/car_control_vehicle_refresh"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_car_control_refresh" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="#15FFFFFF" />

        <!-- 主体：车模 + 参数面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <!-- 兼容旧绑定代码的占位容器 -->
            <LinearLayout
                android:id="@+id/widget_optional_info"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <!-- 左侧：车模 + 位置 + 油量 -->
            <LinearLayout
                android:id="@+id/widget_6x4_car_column"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.32"
                android:orientation="vertical"
                android:paddingEnd="6dp">

                <FrameLayout
                    android:id="@+id/widget_car_frame"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:minHeight="48dp">

                    <ImageView
                        android:id="@+id/widget_car_model"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/car_control_widget_car_model"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/widget_temp_value"
                        style="@style/WidgetCarControlTextSecondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:ellipsize="end"
                        android:gravity="center_horizontal"
                        android:maxLines="1"
                        android:paddingBottom="2dp"
                        android:paddingHorizontal="4dp"
                        android:textSize="9sp"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/widget_vehicle_location"
                    style="@style/WidgetCarControlTextPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:gravity="center_horizontal"
                    android:maxLines="2"
                    android:text="@string/car_control_widget_location_none"
                    android:textSize="9sp"
                    android:visibility="visible" />

                <!-- 油量 -->
                <LinearLayout
                    android:id="@+id/widget_fuel_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/widget_fuel_icon"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/widget_fuel_percent"
                        style="@style/WidgetCarControlTextAccent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="---"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/widget_fuel_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="2dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/widget_car_control_fuel_progress" />
            </LinearLayout>

            <!-- 右侧：参数面板 2×4 网格 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.68"
                android:orientation="vertical"
                android:paddingStart="6dp">

                <!-- 第一行：续航 + 总里程 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/widget_car_control_param_bg"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp">

                        <TextView
                            style="@style/WidgetCarControlTextSecondary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_control_widget_range_label"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/widget_6x4_range"
                            style="@style/WidgetCarControlTextPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="---"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="6dp"
                        android:layout_height="0dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/widget_car_control_param_bg"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp">

                        <TextView
                            style="@style/WidgetCarControlTextSecondary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_control_widget_show_odometer"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/widget_odometer_value"
                            style="@style/WidgetCarControlTextPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="---"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="6dp" />

                <!-- 第二行：电瓶 + 温度 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/widget_car_control_param_bg"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp">

                        <TextView
                            style="@style/WidgetCarControlTextSecondary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_control_widget_show_battery"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/widget_battery_value"
                            style="@style/WidgetCarControlTextPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="---"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <View
                        android:layout_width="6dp"
                        android:layout_height="0dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/widget_car_control_param_bg"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp">

                        <TextView
                            style="@style/WidgetCarControlTextSecondary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_control_widget_show_temp"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/widget_6x4_temp"
                            style="@style/WidgetCarControlTextPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="---"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="6dp" />

                <!-- 第三行：油耗 + 冷却液 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/widget_car_control_param_bg"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp">

                        <TextView
                            style="@style/WidgetCarControlTextSecondary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_control_widget_show_avg_consumption"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/widget_extra_avg_consumption"
                            style="@style/WidgetCarControlTextPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="---"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <View
                        android:layout_width="6dp"
                        android:layout_height="0dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/widget_car_control_param_bg"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp">

                        <TextView
                            style="@style/WidgetCarControlTextSecondary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_control_widget_show_coolant_temp"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/widget_extra_coolant_temp"
                            style="@style/WidgetCarControlTextPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="---"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="6dp" />

                <!-- 第四行：保养 + 转速 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/widget_car_control_param_bg"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp">

                        <TextView
                            style="@style/WidgetCarControlTextSecondary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_control_widget_show_service_distance"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/widget_extra_service_distance"
                            style="@style/WidgetCarControlTextPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="---"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <View
                        android:layout_width="6dp"
                        android:layout_height="0dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/widget_car_control_param_bg"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp">

                        <TextView
                            style="@style/WidgetCarControlTextSecondary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/car_control_widget_show_engine_speed"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/widget_extra_engine_speed"
                            style="@style/WidgetCarControlTextPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="---"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 底部：胎压条 + 按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 胎压 + 手刹 一行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/widget_tire_block"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.65"
                    android:background="@drawable/widget_car_control_param_bg"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/widget_tire_lf"
                        style="@style/WidgetCarControlTextSecondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/widget_tire_rf"
                        style="@style/WidgetCarControlTextSecondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/widget_tire_lr"
                        style="@style/WidgetCarControlTextSecondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/widget_tire_rr"
                        style="@style/WidgetCarControlTextSecondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:textSize="8sp" />
                </LinearLayout>

                <View
                    android:layout_width="6dp"
                    android:layout_height="0dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.35"
                    android:background="@drawable/widget_car_control_param_bg"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp">

                    <TextView
                        style="@style/WidgetCarControlTextSecondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/car_control_widget_show_epb"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/widget_extra_epb"
                        style="@style/WidgetCarControlTextPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- 按钮栏 -->
            <LinearLayout
                android:id="@+id/widget_buttons_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="4">

                <LinearLayout
                    android:id="@+id/widget_btn0"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <ImageView
                        android:id="@+id/widget_btn0_icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/widget_btn1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <ImageView
                        android:id="@+id/widget_btn1_icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/widget_btn2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <ImageView
                        android:id="@+id/widget_btn2_icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/widget_btn3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <ImageView
                        android:id="@+id/widget_btn3_icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 确认遮罩 -->
    <FrameLayout
        android:id="@+id/widget_confirm_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/widget_confirm_scrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="fitXY"
            android:src="@drawable/widget_car_control_scrim" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/widget_confirm_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_confirm_cancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/widget_car_control_confirm_btn"
                    android:gravity="center"
                    android:minHeight="32dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp"
                    android:text="@string/car_control_widget_confirm_cancel"
                    android:textColor="#FFFFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/widget_confirm_ok"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/widget_car_control_confirm_btn"
                    android:gravity="center"
                    android:minHeight="32dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp"
                    android:text="@string/car_control_widget_confirm_ok"
                    android:textColor="#FFFFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
