<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_projection_dpi"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/apps_projection_dpi_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_projection_dpi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/text_projection_rotation_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/apps_projection_rotation_title"
        android:textAppearance="?attr/textAppearanceTitleSmall" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_projection_rotation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_projection_rotation_0"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/features_rear_rotation_deg_0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_projection_rotation_90"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/features_rear_rotation_deg_90" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_projection_rotation_180"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/features_rear_rotation_deg_180" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_projection_rotation_270"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/features_rear_rotation_deg_270" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <TextView
        android:id="@+id/text_projection_official_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/apps_projection_dialog_official_section"
        android:textAppearance="?attr/textAppearanceTitleSmall" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switch_projection_disable_official"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/apps_projection_dialog_official_switch"
        android:textAppearance="@style/TextAppearance.MiRoot.SwitchLabel" />

    <TextView
        android:id="@+id/text_projection_official_switch_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?android:attr/textColorSecondary" />

    <TextView
        android:id="@+id/text_projection_config_tip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/apps_projection_dialog_tip"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?android:attr/textColorSecondary" />
</LinearLayout>
