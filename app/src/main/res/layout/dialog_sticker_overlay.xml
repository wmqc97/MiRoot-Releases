<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:paddingStart="@dimen/mi_card_inner_padding"
    android:paddingEnd="@dimen/mi_card_inner_padding"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_sticker_enabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/features_sticker_enable"
            android:textAppearance="@style/TextAppearance.MiRoot.SwitchLabel" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_sticker_pick"
                style="@style/Widget.MiRoot.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/features_sticker_pick_image" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_sticker_clear"
                style="@style/Widget.MiRoot.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/features_sticker_clear_image" />
        </LinearLayout>

        <ImageView
            android:id="@+id/image_sticker_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:adjustViewBounds="true"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/features_sticker_preview_content_desc"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:maxHeight="240dp"
            android:minHeight="100dp"
            android:scaleType="fitCenter" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_sticker_rounded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/features_sticker_rounded"
            android:textAppearance="@style/TextAppearance.MiRoot.SwitchLabel" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_sticker_corner_dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/features_sticker_corner_dp_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_sticker_corner_dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_sticker_center_horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/features_sticker_center_horizontal"
            android:textAppearance="@style/TextAppearance.MiRoot.SwitchLabel" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_sticker_center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/features_sticker_center_vertical"
            android:textAppearance="@style/TextAppearance.MiRoot.SwitchLabel" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_sticker_x"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:hint="@string/settings_overlay_x">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_sticker_x"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberSigned"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_sticker_y"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:hint="@string/settings_overlay_y">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_sticker_y"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberSigned"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_sticker_w"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:hint="@string/features_sticker_width"
                app:placeholderText="@string/features_sticker_w_placeholder">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_sticker_w"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberSigned"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_sticker_h"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:hint="@string/features_sticker_height">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_sticker_h"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberSigned"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/features_sticker_scale_section"
            android:textAppearance="@style/TextAppearance.MiRoot.CardSectionTitle" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_sticker_scale_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_sticker_scale_stretch"
                style="@style/Widget.MiRoot.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:minHeight="40dp"
                android:text="@string/features_sticker_scale_stretch" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_sticker_scale_fit"
                style="@style/Widget.MiRoot.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:minHeight="40dp"
                android:text="@string/features_sticker_scale_fit" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_sticker_scale_crop"
                style="@style/Widget.MiRoot.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:minHeight="40dp"
                android:text="@string/features_sticker_scale_crop" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_reset_sticker"
            style="@style/Widget.MiRoot.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"
            android:text="@string/features_sticker_reset" />
    </LinearLayout>
</ScrollView>
