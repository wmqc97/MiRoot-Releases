<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mi_page_bg"
    android:orientation="vertical"
    android:paddingStart="@dimen/mi_page_scroll_padding"
    android:paddingTop="0dp"
    android:paddingEnd="@dimen/mi_page_scroll_padding"
    android:paddingBottom="0dp">

    <EditText
        android:id="@+id/edit_apps_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/apps_search_hint"
        android:importantForAutofill="no"
        android:inputType="text|textNoSuggestions"
        android:maxLines="1"
        tools:ignore="SpeakableTextPresent" />

    <TextView
        android:id="@+id/text_apps_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/apps_subtitle"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="@color/mi_text_secondary" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        tools:listitem="@layout/item_installed_app" />

    <TextView
        android:id="@+id/text_apps_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/apps_empty"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:visibility="gone" />
</LinearLayout>
