<?xml version="1.0" encoding="utf-8"?>
<!-- 背屏充电：底层视频/图片背景 + 水波液面 + 闪电/电量/信息 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/charging_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/charging_window_bg">

    <TextureView
        android:id="@+id/charging_background_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <com.wmqc.miroot.charging.GyroWaterRippleView
        android:id="@+id/gyro_water_ripple"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 避让包装层：左 padding 留给摄像头区域，子元素在其可见区域内居中/底部 -->
    <FrameLayout
        android:id="@+id/safe_area_wrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false">

        <!-- ⚡ 73% 在可见区域居中 -->
        <LinearLayout
            android:id="@+id/center_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/lightning_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_lightning" />

            <TextView
                android:id="@+id/battery_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:letterSpacing="0.05"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="6"
                android:shadowRadius="12"
                android:text="100%"
                android:textColor="#FFFFFFFF"
                android:textSize="60sp" />
        </LinearLayout>

        <!-- 底部信息卡：无背景，在可见区域底部居中 -->
        <LinearLayout
            android:id="@+id/charging_info_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingVertical="14dp"
            android:visibility="gone" />
    </FrameLayout>
</FrameLayout>
