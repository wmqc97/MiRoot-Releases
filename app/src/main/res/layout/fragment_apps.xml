<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mi_page_bg"
    android:orientation="vertical"
    android:paddingStart="@dimen/mi_page_scroll_padding"
    android:paddingTop="@dimen/mi_page_content_padding_top"
    android:paddingEnd="@dimen/mi_page_scroll_padding"
    android:paddingBottom="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="40dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/text_apps_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/apps_title"
            android:textAppearance="@style/TextAppearance.MiRoot.PageTitle" />

        <TextView
            android:id="@+id/text_rear_desktop_mode_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/miuix_primary"
            tools:text="全部应用·蜂窝环形" />

        <ImageButton
            android:id="@+id/button_apps_desktop_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/apps_rear_desktop_projection_settings_cd"
            android:padding="8dp"
            app:srcCompat="@drawable/ic_line_settings"
            app:tint="?attr/colorControlNormal" />
    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_installed_apps_host"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1" />
</LinearLayout>
