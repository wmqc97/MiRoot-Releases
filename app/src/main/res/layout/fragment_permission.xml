<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mi_page_bg"
    android:fillViewport="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/mi_page_scroll_padding"
        android:paddingTop="@dimen/mi_page_scroll_padding"
        android:paddingEnd="@dimen/mi_page_scroll_padding"
        android:paddingBottom="@dimen/mi_page_scroll_padding">

        <!-- 顶部：左侧状态卡片 + 右侧 Root / Shizuku 入口（底对齐至右侧 Shizuku 卡片底） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="bottom"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_permission_status"
                style="@style/Widget.MiRoot.Card.PermissionStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_weight="1"
                android:minHeight="140dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="140dp">

                    <!-- 底图叠层：向右下略加深，打钩叠在其右下角之上 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_perm_status_card_decoration" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:orientation="vertical"
                        android:paddingStart="18dp"
                        android:paddingTop="22dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="22dp">

                        <TextView
                            android:id="@+id/text_perm_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:textAppearance="@style/TextAppearance.MiRoot.CardSectionTitle"
                            tools:text="MiRoot · Root" />

                        <TextView
                            android:id="@+id/text_perm_version"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingStart="4dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="4dp"
                            android:paddingBottom="2dp"
                            android:textAppearance="@style/TextAppearance.MiRoot.Body"
                            android:textSize="14sp"
                            android:contentDescription="@string/settings_version_cd_readme"
                            tools:text="v1.3" />

                        <TextView
                            android:id="@+id/text_os_version"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="4dp"
                            android:paddingTop="2dp"
                            android:paddingEnd="4dp"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:textAppearance="@style/TextAppearance.MiRoot.Body"
                            android:textColor="@color/mi_text_secondary"
                            android:textSize="12sp"
                            tools:text="Android 16 · API 36" />

                        <TextView
                            android:id="@+id/text_subscreen_version"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="4dp"
                            android:paddingTop="2dp"
                            android:paddingEnd="4dp"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:textAppearance="@style/TextAppearance.MiRoot.Body"
                            android:textColor="@color/mi_text_secondary"
                            android:textSize="12sp"
                            tools:text="背屏 v2.1.0" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/image_perm_state"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="4dp"
                        android:alpha="0.35"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        tools:src="@drawable/ic_perm_status_tick_large" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="88dp"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/card_action_force_stop"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="end"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/content_desc_force_stop"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_power"
                        app:tint="?attr/colorOnSurface" />
                </FrameLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_action_root"
                    style="@style/Widget.MiRoot.Card"
                    android:layout_width="88dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/text_action_root"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/perm_short_root"
                        android:textAppearance="@style/TextAppearance.MiRoot.Title"
                        android:textSize="15sp" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_action_shizuku"
                    style="@style/Widget.MiRoot.Card"
                    android:layout_width="88dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/text_action_shizuku"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/perm_short_shizuku"
                        android:textAppearance="@style/TextAppearance.MiRoot.Title"
                        android:textSize="15sp" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <!-- 权限授权状态 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_runtime_auth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mi_page_scroll_padding"
            app:cardBackgroundColor="@color/mi_card_surface"
            app:cardCornerRadius="@dimen/mi_corner_radius"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/text_section_runtime_auth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="@string/runtime_auth_section"
                    android:textAppearance="@style/TextAppearance.MiRoot.CardSectionTitle" />

                <LinearLayout
                    android:id="@+id/row_storage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/runtime_auth_storage"
                        android:textAppearance="@style/TextAppearance.MiRoot.Body"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/status_storage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.MiRoot.BodyStrong"
                        android:textSize="14sp"
                        tools:text="@string/runtime_auth_denied" />
                </LinearLayout>

                <View
                    android:id="@+id/divider_after_storage"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/mi_divider" />

                <LinearLayout
                    android:id="@+id/row_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/runtime_auth_overlay"
                        android:textAppearance="@style/TextAppearance.MiRoot.Body"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/status_overlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.MiRoot.BodyStrong"
                        android:textSize="14sp"
                        tools:text="@string/runtime_auth_denied" />
                </LinearLayout>

                <View
                    android:id="@+id/divider_after_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/mi_divider" />

                <LinearLayout
                    android:id="@+id/row_battery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/runtime_auth_battery"
                        android:textAppearance="@style/TextAppearance.MiRoot.Body"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/status_battery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.MiRoot.BodyStrong"
                        android:textSize="14sp"
                        tools:text="@string/runtime_auth_denied" />
                </LinearLayout>

                <View
                    android:id="@+id/divider_after_battery"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/mi_divider" />

                <LinearLayout
                    android:id="@+id/row_post_notifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/runtime_auth_post_notifications"
                        android:textAppearance="@style/TextAppearance.MiRoot.Body"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/status_post_notifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.MiRoot.BodyStrong"
                        android:textSize="14sp"
                        tools:text="@string/runtime_auth_denied" />
                </LinearLayout>

                <View
                    android:id="@+id/divider_after_post_notifications"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/mi_divider" />

                <LinearLayout
                    android:id="@+id/row_app_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/runtime_auth_app_list"
                        android:textAppearance="@style/TextAppearance.MiRoot.Body"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/status_app_list"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.MiRoot.BodyStrong"
                        android:textSize="14sp"
                        tools:text="@string/runtime_auth_denied" />
                </LinearLayout>

                <View
                    android:id="@+id/divider_after_app_list"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/mi_divider" />

                <LinearLayout
                    android:id="@+id/row_notification"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/runtime_auth_notification"
                        android:textAppearance="@style/TextAppearance.MiRoot.Body"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/status_notification"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.MiRoot.BodyStrong"
                        android:textSize="14sp"
                        tools:text="@string/runtime_auth_denied" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 酷安 / 爱发电 / 关于 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_more"
            style="@style/Widget.MiRoot.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mi_page_scroll_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/row_coolapk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:contentDescription="@string/settings_coolapk_cd"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="14dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:scaleType="fitCenter"
                        android:src="@drawable/kuan" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_coolapk_title"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/mi_text_primary" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_chevron_right"
                        app:tint="@color/mi_text_secondary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/mi_divider" />

                <LinearLayout
                    android:id="@+id/row_sponsor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:contentDescription="@string/settings_sponsor_cd"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="14dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/ic_sponsor_ifdian" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_sponsor_title"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/mi_text_primary" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_chevron_right"
                        app:tint="@color/mi_text_secondary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/mi_divider" />

                <LinearLayout
                    android:id="@+id/row_about"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="14dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:scaleType="fitCenter"
                        android:src="@mipmap/ic_launcher" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_about"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/mi_text_primary" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_chevron_right"
                        app:tint="@color/mi_text_secondary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_update"
            style="@style/Widget.MiRoot.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mi_page_scroll_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/update_title"
                        android:textAppearance="@style/TextAppearance.MiRoot.CardSectionTitle" />

                    <View
                        android:id="@+id/badge_update_dot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginStart="6dp"
                        android:layout_marginBottom="2dp"
                        android:background="@drawable/shape_badge_dot"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/text_update_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textAppearance="@style/TextAppearance.MiRoot.Body"
                    android:textSize="14sp"
                    tools:text="当前版本 1.8.9" />

                <TextView
                    android:id="@+id/text_update_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="@style/TextAppearance.MiRoot.Body"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:text="发现新版本 1.9.0"
                    tools:visibility="visible" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_update"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:indeterminate="false"
                    android:visibility="gone"
                    tools:progress="42"
                    tools:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_check_update"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/update_check_button" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_refresh"
            style="@style/Widget.MiRoot.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/mi_page_scroll_padding"
            android:text="@string/action_refresh" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
